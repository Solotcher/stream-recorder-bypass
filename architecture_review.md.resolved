## 3. 모듈별 상세 명세 (Gemini 3.1 Pro 작업용)

### 3.1 `app/commands/base.py` [NEW]

```python
"""
Command Pattern 기반 녹화 커맨드 빌더 인터페이스.
각 플랫폼(Streamlink/yt-dlp)이 이 인터페이스를 구현하여
trigger_recording의 God Function을 분해합니다.
"""
from abc import ABC, abstractmethod
from typing import List, Dict, Any


class CommandBuilder(ABC):
    """녹화 프로세스 실행을 위한 CLI 커맨드를 조립하는 추상 빌더"""
    
    @abstractmethod
    def build_command(
        self,
        stream_url: str,
        output_path: str,
        resolution: str,
        extra_args: List[str] = None
    ) -> List[str]:
        """
        플랫폼별 녹화 커맨드(리스트 형태)를 조립하여 반환.
        
        Args:
            stream_url: 스트림 원본 URL
            output_path: 녹화 파일 저장 절대 경로
            resolution: 화질 선호도 (best, 1080p60 등)
            extra_args: 추가 인자 (쿠키, 인증 헤더 등)
        
        Returns:
            subprocess.Popen에 전달할 커맨드 리스트
        """
        # TODO: Gemini 3.1 Pro 구현 - 반환 타입은 List[str]
        pass

    @abstractmethod
    def get_output_extension(self) -> str:
        """
        이 빌더가 생성하는 녹화 파일의 확장자를 반환합니다.
        예: '.ts' (Streamlink), '.mp4' (yt-dlp)
        """
        # TODO: Gemini 3.1 Pro 구현 - Streamlink → '.ts', yt-dlp → '.mp4'
        pass

    @abstractmethod
    def needs_remuxing(self) -> bool:
        """녹화 완료 후 리먹싱(.ts → .mp4)이 필요한지 여부"""
        # TODO: Gemini 3.1 Pro 구현 - Streamlink → True, yt-dlp → False
        pass
```

