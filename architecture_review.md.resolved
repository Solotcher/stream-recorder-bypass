### 3.6 `app/events/types.py` [NEW]

```python
"""
내부 이벤트 정의. 녹화 생명주기 이벤트를 dataclass로 표현합니다.

Integration Point:
  - 기존 event_bus.py의 broadcast_event(type, dict) 호출을 정형화된 이벤트 객체로 대체
"""
from dataclasses import dataclass
from datetime import datetime
from typing import Optional


@dataclass
class RecordingStartedEvent:
    channel_id: str
    platform: str
    channel_name: str
    record_type: str  # "manual" or "scheduled"
    output_path: str
    started_at: datetime

@dataclass
class RecordingFinishedEvent:
    channel_id: str
    platform: str
    channel_name: str
    output_path: str
    needs_remuxing: bool      # Streamlink → True, yt-dlp → False
    is_soop_part: bool        # SOOP 분할 파트 여부
    session_part: int         # 현재 파트 번호

@dataclass
class PostProcessingCompleteEvent:
    channel_name: str
    output_path: str
    file_size_bytes: int
    final_format: str         # "mp4", "ts" 등
```

