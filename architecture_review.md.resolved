        # TODO: Gemini 3.1 Pro 구현
        # 1. channel_id가 _sessions에 없으면 새 RecordingSession 생성 (started_at = now)
        # 2. 이미 있으면 part += 1
        # 참조: 기존 scheduler.py L62-71
        pass

    @classmethod
    def end_session(cls, channel_id: str) -> Optional[RecordingSession]:
