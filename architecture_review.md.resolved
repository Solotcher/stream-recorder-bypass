        # 2. platform == "tiktok" 분기: settings.YTDLP_PATH + [tiktok_url, "--no-playlist", "-o", output_path]
        # 참조: 기존 scheduler.py L128-140
        pass

    def get_output_extension(self):
        return ".mp4"

    def needs_remuxing(self):
        return False
```

